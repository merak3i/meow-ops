# Logs
logs
*.log
npm-debug.log*

node_modules
dist
dist-ssr
*.local

# Secrets
.env
.env.local
.env.*.local

# Local sync state — never commit
sync/.meow-ops-sync-state.json
sync/auto-sync.log
public/data/*
# sessions.json, cost-summary.json and rate-limits.json are LOCAL-ONLY: they
# carry real session data and personal usage/billing figures and were removed
# from the public repo (history purge 2026-06-12; rate-limits untracked
# 2026-07-06). The hosted demo serves demo-* files via vercel.json rewrites;
# the local API (sync/local-api.mjs) serves the fresh local copies.
# Never re-allowlist anything under public/data except demo-* files.
!public/data/demo-sessions.json
!public/data/demo-cost-summary.json
!public/data/demo-superadmin-usage.json

# Local session-history files (Pomodoro, etc.) live in the browser, not the repo
*.history.json

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.sw?

# Deploy
.vercel

# Playwright e2e artifacts — generated per-run, never commit
test-results/
playwright-report/

# Claude Code session metadata
.claude/
.claude-history/
