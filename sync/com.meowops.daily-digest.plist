<?xml version="1.0" encoding="UTF-8"?>
<!--
  Meow Operations — one daily operator cycle (macOS)

  Install:
    cp sync/com.meowops.daily-digest.plist ~/Library/LaunchAgents/ && launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.meowops.daily-digest.plist

  Unload:
    launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/com.meowops.daily-digest.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.meowops.daily</string>
  <key>ProgramArguments</key>
  <array>
    <string>YOUR_NODE_PATH</string>
    <string>YOUR_REPO_PATH/sync/daily-operator.mjs</string>
  </array>
  <key>WorkingDirectory</key>
  <string>YOUR_REPO_PATH</string>
  <!-- launchd calendar intervals use the machine's local time. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>YOUR_HOME/Library/Logs/meow-ops/daily.log</string>
  <key>StandardErrorPath</key>
  <string>YOUR_HOME/Library/Logs/meow-ops/daily.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>YOUR_HOME</string>
  </dict>
</dict>
</plist>
