<?xml version="1.0" encoding="UTF-8"?>
<!--
  Meow Operations — auto-sync launchd template (macOS)

  Replace YOUR_HOME and YOUR_REPO_PATH with your own paths, then:
    cp sync/launchd-example.plist ~/Library/LaunchAgents/com.meow-ops.sync.plist
    launchctl load ~/Library/LaunchAgents/com.meow-ops.sync.plist

  To unload:
    launchctl unload ~/Library/LaunchAgents/com.meow-ops.sync.plist

  To force a run right now:
    launchctl kickstart gui/$(id -u)/com.meow-ops.sync
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.meow-ops.sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>YOUR_REPO_PATH/sync/full-sync.mjs</string>
    </array>

    <key>WorkingDirectory</key>
    <string>YOUR_REPO_PATH</string>

    <!-- Run every hour -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>YOUR_REPO_PATH/sync/auto-sync.log</string>

    <key>StandardErrorPath</key>
    <string>YOUR_REPO_PATH/sync/auto-sync.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>YOUR_HOME</string>
    </dict>
</dict>
</plist>
