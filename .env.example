# Copy this file to .env and fill in the values.
# Never commit .env — it is in .gitignore.

# ─── Supabase (optional) ─────────────────────────────────────────────────
# Only needed if you want to host the dashboard data in a public Supabase
# Storage bucket so the deployed PWA can fetch it from anywhere.
# Leave blank to run fully local (Vite dev mode reads from public/data/sessions.json).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public URL of your sessions.json in Supabase Storage.
# Format: https://<project>.supabase.co/storage/v1/object/public/<bucket>/sessions.json
# Used at build time. The bundled production app fetches from this URL.
VITE_SESSIONS_URL=

# Service-role key — local-only, used by sync/upload-to-supabase.mjs.
# NEVER expose this to the browser. NEVER commit it.
SUPABASE_SERVICE_KEY=

# ─── SuperAdmin Capacity & Usage (optional, local-only) ─────────────────
# Used by sync/superadmin-usage.mjs. These values are read on your machine
# and the browser receives only public/data/superadmin-usage.json.

# Comma-separated GitHub repos to summarize through `gh api`.
MEOW_SUPERADMIN_GITHUB_REPOS=merak3i/meow-ops,merak3i/patherle,merak3i/patherle-agentic-loop-ops,merak3i/meow-creative-haus-2

# Optional local JSON export from your SuperAdmin DB or subscription tracker.
# Supported shapes: [{...}], { "services": [...] }, { "rows": [...] },
# or { "saas": { "services": [...] } }.
MEOW_SUPERADMIN_USAGE_SNAPSHOT=

# Optional limits so the dashboard can show usage percentage.
MEOW_GITHUB_ACTIONS_MINUTES_LIMIT=
MEOW_GITHUB_ACTIONS_STORAGE_GB_LIMIT=

# ─── Sync behavior (all optional, local-only) ───────────────────────────────

# Day/week/month boundaries use your system timezone by default. Override here
# (any IANA zone, e.g. America/New_York) if you want fixed reporting boundaries.
MEOW_TZ=

# Strict "metrics only" mode. When set (1/true/yes), the exporter captures NO
# first-message snippet or session title for any source — just counts and timing.
MEOW_NO_SNIPPETS=

# Google Antigravity agent sessions. Defaults to ~/.gemini/antigravity. Override
# if your install stores the "brain" directory elsewhere.
ANTIGRAVITY_DIR=

# ─── Loop-Ops live truth from Supabase (optional, plug-in-later) ────────────
# The Excel workbook is the STRUCTURE (which surfaces exist); these pull the
# live STATE (gate pass/fail, db status, last-verified) from a Supabase table
# into the truth CSV the Loom importer consumes. Leave blank = Excel-only.
# These keys/table are private — they live here (gitignored), never in code.
LOOP_OPS_SUPABASE_URL=
LOOP_OPS_SUPABASE_KEY=
LOOP_OPS_SUPABASE_TABLE=
# Optional JSON remap if your column names differ from the importer's truth
# columns, e.g. {"latest_gate":"e2e_gate","current_truth":"truth_value"}
LOOP_OPS_SUPABASE_COLMAP=
# Where the connector writes the truth CSV (importer reads it via --truth).
# Defaults to public/data/loop-ops/truth.csv (gitignored).
LOOP_OPS_TRUTH=

# Cap the number of sessions written to sessions.json (browser payload size).
# Cost-summary.json is always computed from the full set. Default 1000.
MEOW_MAX_SESSIONS=

# ─── Local sync API (sync/local-api.mjs) ────────────────────────────────────

# If you access the dashboard from a hosted (Vercel) URL that calls your local
# API on port 7337, set the exact hosted origin(s) here (comma-separated) so the
# server allowlists them. Localhost origins are always allowed. Without this,
# only localhost can reach the API (cross-origin requests are rejected).
MEOW_DASHBOARD_ORIGIN=
