# Copy this file to .env and fill in the values.
# Never commit .env — it is in .gitignore.

# ─── Supabase (optional) ─────────────────────────────────────────────────
# Only needed for optional Scrying Sanctum realtime features.
# Session analytics are local-only by default and are not loaded from Supabase.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override for the local sync helper URL.
# Default: http://127.0.0.1:7337
VITE_LOCAL_SYNC_URL=

# Service-role key — local-only, only needed if you intentionally use the
# advanced upload-to-supabase script. NEVER expose this to the browser.
SUPABASE_SERVICE_KEY=
